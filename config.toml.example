[app]
admin_password = 'checkpost_password'
admin_username = 'checkpost_admin'
http_tls_cert = 'testdata/server_cert.pem'
http_tls_key = 'testdata/server_key.pem'
root_url = 'http://localhost:1323'
enrollment_key = 'replace-with-a-random-secret'
use_tls = false
policy_update_interval = '1h'
policy_stale_after = '2h'

[app.oidc]
# SSO via OpenID Connect. issuer, client_id and client_secret must be set
# together (all-or-nothing); when empty, only password login is offered.
issuer = ''
client_id = ''
client_secret = ''
# Button label shown on the login page.
label = 'Company SSO'
# Defaults to <root_url>/auth/callback when empty.
redirect_url = ''
# Optional endpoint overrides. Endpoints are normally discovered from the
# issuer; override when the browser-facing host differs from the server-side
# host (e.g. dex behind docker: issuer/token at dex:5556, auth at localhost:5556).
auth_url = ''
token_url = ''
scopes = ['openid', 'profile', 'email', 'groups']
# ID-token claim to read user-group memberships from.
groups_claim = 'groups'
# Restrict logins to these email domains. Empty = allow any domain.
allowed_domains = []
# Provision a user row on first successful SSO login.
auto_create_users = true
# Optional global role auto-bound to new SSO users: admin|operator|analyst|viewer.
# Empty = no access until an admin grants a role binding.
default_role = ''

[app.session]
# Cookie + server-side session lifetime.
ttl = '8h'

[osquery_bootstrap]
enabled = true

[osquery_bootstrap.linux.tarball_amd64]
url = ''
sha256 = ''

[osquery_bootstrap.linux.tarball_arm64]
url = ''
sha256 = ''

[osquery_bootstrap.macos.pkg_universal]
url = ''
sha256 = ''

[osquery_bootstrap.windows.msi_amd64]
url = ''
sha256 = ''

# osquery-nftables-ext: adds an `nftables` table to osquery on Linux. The
# extension shells out to `nft -j list ruleset` (read-only) and never modifies
# firewall state. Rendered into the Linux bootstrap script. Set enabled = false
# (or leave the per-arch url empty) to skip installing it.
[osquery_bootstrap.extensions.nftables]
enabled = true

[osquery_bootstrap.extensions.nftables.linux.tarball_amd64]
# Release tarball from https://github.com/codingCoffee/osquery-nftables-ext/releases
# e.g. .../v0.3.0/osquery-nftables-ext_0.3.0_linux_amd64.tar.gz
url = ''
sha256 = ''

[osquery_bootstrap.extensions.nftables.linux.tarball_arm64]
url = ''
sha256 = ''

[db]
dbname = 'checkpost'
host = '127.0.0.1'
password = 'checkpost'
port = 5432
user = 'checkpost'

[results]
# Which backend powers the in-app results browser. Both parquet
# and clickhouse can serve reads; ndjson is write-only. The named backend must
# be enabled, otherwise startup fails.
#   ''           auto: prefer parquet, else clickhouse
#   'parquet'    local Parquet+DuckDB
#   'clickhouse' ClickHouse (for stateless/multi-instance deploys)
reader = ''

[results.parquet]
# Local Parquet+DuckDB backend. Serves the in-app results browser when selected
# by results.reader. With no reader-capable backend enabled, the
# browser reports browsing as unavailable.
enabled = true
# Root directory where scheduled-query Parquet files are written.
# An absolute path is recommended in production.
root = './data/results'
# Path to a persistent DuckDB catalog file. Empty = in-memory (re-scans
# Parquet metadata on cold start). Set a path to persist catalogs/indexes.
duckdb_path = ''

[results.adhoc]
# Retention (days) for ad-hoc / multi-host query-run result rows. Schedule
# retention is unaffected (per-schedule retention_days).
retention_days = 30

[results.ndjson]
# Ship rows as newline-delimited JSON to a file or stdout for an external agent
# (Vector, Fluent Bit, ...) to tail. Rotation is handled by the host/agent.
enabled = false
path = 'stdout'
# required = true makes overflow fail ingest with 503 (default best-effort).
required = false

[results.clickhouse]
# Insert rows into a ClickHouse table. The table is created on startup.
enabled = false
# DSN is a secret; prefer an env var (CHECKPOST_RESULTS__CLICKHOUSE__DSN) and
# use secure=true for remote servers.
dsn = 'clickhouse://user:pass@host:9000/checkpost?secure=true'
table = 'query_results'
# Coarse global retention. 0 = no TTL.
ttl_days = 0
# required = true makes errors/overflow fail ingest with 503 (default best-effort).
required = false

[alerts]
# Master switch for the alerting engine. When false, no rules are evaluated.
enabled = false

[alerts.smtp]
# Global relay for all SMTP targets. An empty host disables SMTP delivery.
host = ''
port = 587
username = ''
# Prefer the CHECKPOST_ALERTS__SMTP__PASSWORD env var over storing this here.
password = ''
from = 'checkpost@example.com'
# starttls | implicit | none (none is discouraged; dev/trusted networks only)
tls = 'starttls'
