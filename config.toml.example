[app]
admin_password = 'watcher_password'
admin_username = 'watcher_admin'
http_tls_cert = 'testdata/server_cert.pem'
http_tls_key = 'testdata/server_key.pem'
root_url = 'http://localhost:1323'
secure_cookie_key = 'cddc196bdf9e76c9a343ed8fb33a553e'
use_tls = false
policy_update_interval = '1h'
policy_stale_after = '2h'

[app.oidc]
# SSO via OpenID Connect. issuer, client_id and client_secret must be set
# together (all-or-nothing); when empty, only password login is offered.
issuer = ''
client_id = ''
client_secret = ''
# Button label shown on the login page.
label = 'Company SSO'
# Defaults to <root_url>/auth/callback when empty.
redirect_url = ''
# Optional endpoint overrides. Endpoints are normally discovered from the
# issuer; override when the browser-facing host differs from the server-side
# host (e.g. dex behind docker: issuer/token at dex:5556, auth at localhost:5556).
auth_url = ''
token_url = ''
scopes = ['openid', 'profile', 'email', 'groups']
# ID-token claim to read user-group memberships from.
groups_claim = 'groups'
# Restrict logins to these email domains. Empty = allow any domain.
allowed_domains = []
# Provision a user row on first successful SSO login.
auto_create_users = true
# Optional global role auto-bound to new SSO users: admin|operator|analyst|viewer.
# Empty = no access until an admin grants a role binding.
default_role = ''

[app.session]
# Cookie + server-side session lifetime.
ttl = '8h'

[osquery_bootstrap]
enabled = true

[osquery_bootstrap.linux.deb_amd64]
url = ''
sha256 = ''

[osquery_bootstrap.linux.deb_arm64]
url = ''
sha256 = ''

[osquery_bootstrap.linux.rpm_amd64]
url = ''
sha256 = ''

[osquery_bootstrap.linux.rpm_arm64]
url = ''
sha256 = ''

[osquery_bootstrap.macos.pkg_universal]
url = ''
sha256 = ''

[osquery_bootstrap.windows.msi_amd64]
url = ''
sha256 = ''

[db]
dbname = 'watcher'
host = '127.0.0.1'
password = 'watcher'
port = 5432
user = 'watcher'

[data]
# Root directory where scheduled-query Parquet files are written.
# An absolute path is recommended in production.
parquet_root = './data/results'
# Path to a persistent DuckDB catalog file. Empty = in-memory (re-scans
# Parquet metadata on cold start). Set a path to persist catalogs/indexes.
duckdb_path = ''

[alerts]
# Master switch for the alerting engine. When false, no rules are evaluated.
enabled = false

[alerts.smtp]
# Global relay for all SMTP targets. An empty host disables SMTP delivery.
host = ''
port = 587
username = ''
# Prefer the WATCHER_ALERTS__SMTP__PASSWORD env var over storing this here.
password = ''
from = 'watcher@example.com'
# starttls | implicit | none (none is discouraged; dev/trusted networks only)
tls = 'starttls'
