#!/usr/bin/env bash
set -euo pipefail

TLS_HOSTNAME={{ sh .TLSHostname }}
ENROLL_SECRET={{ sh .EnrollmentKey }}
FLAGS_PATH="/etc/osquery/osquery.flags"
SECRET_PATH="/etc/osquery/enroll_secret"
SERVICE_PATH="/etc/systemd/system/osqueryd.service"
OSQUERY_PREFIX="/opt/osquery"
TARBALL_AMD64_URL={{ sh .LinuxTarballAMD64URL }}
TARBALL_AMD64_SHA256={{ sh .LinuxTarballAMD64SHA256 }}
TARBALL_ARM64_URL={{ sh .LinuxTarballARM64URL }}
TARBALL_ARM64_SHA256={{ sh .LinuxTarballARM64SHA256 }}

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    echo "Run as root."
    exit 1
  fi
}

require_tar() {
  if ! command -v tar >/dev/null 2>&1; then
    echo "tar is required to extract the osquery tarball."
    exit 1
  fi
}

cleanup_staging() {
  if [[ -n "${STAGING_DIR:-}" ]]; then
    rm -rf "${STAGING_DIR}"
  fi
}

download_file() {
  local url="$1"
  local output="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fL --retry 3 --connect-timeout 15 -o "${output}" "${url}"
  elif command -v wget >/dev/null 2>&1; then
    wget -O "${output}" "${url}"
  else
    echo "curl or wget is required to download osquery."
    exit 1
  fi
}

actual_sha256() {
  local path="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "${path}" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "${path}" | awk '{print $1}'
  else
    echo "sha256sum or shasum is required to verify osquery package integrity."
    exit 1
  fi
}

verify_sha256() {
  local path="$1"
  local expected="$2"
  local actual
  actual="$(actual_sha256 "${path}")"
  if [[ "${actual}" != "${expected}" ]]; then
    echo "SHA256 mismatch for ${path}."
    echo "Expected: ${expected}"
    echo "Actual:   ${actual}"
    exit 1
  fi
}

arch_key() {
  case "$(uname -m)" in
    x86_64|amd64) echo "amd64" ;;
    aarch64|arm64) echo "arm64" ;;
    *)
      echo "Unsupported architecture: $(uname -m)" >&2
      exit 1
      ;;
  esac
}

select_tarball() {
  local arch="$1"
  case "${arch}" in
    amd64) PACKAGE_URL="${TARBALL_AMD64_URL}"; PACKAGE_SHA256="${TARBALL_AMD64_SHA256}" ;;
    arm64) PACKAGE_URL="${TARBALL_ARM64_URL}"; PACKAGE_SHA256="${TARBALL_ARM64_SHA256}" ;;
    *) echo "No osquery tarball mapping for ${arch}." >&2; exit 1 ;;
  esac

  if [[ -z "${PACKAGE_URL}" || -z "${PACKAGE_SHA256}" ]]; then
    echo "Checkpost is missing the osquery tarball URL or SHA256 for ${arch}."
    exit 1
  fi
}

install_osquery_if_missing() {
  if [[ -x "${OSQUERY_PREFIX}/bin/osqueryd" ]] || command -v osqueryd >/dev/null 2>&1; then
    echo "osquery is already installed; reconfiguring Checkpost enrollment."
    return
  fi

  require_tar

  local arch
  arch="$(arch_key)"
  select_tarball "${arch}"

  STAGING_DIR="$(mktemp -d "/tmp/checkpost-osquery.XXXXXX")"
  trap cleanup_staging EXIT
  local tarball_path="${STAGING_DIR}/osquery.tar.gz"
  download_file "${PACKAGE_URL}" "${tarball_path}"
  verify_sha256 "${tarball_path}" "${PACKAGE_SHA256}"

  tar -xzf "${tarball_path}" -C "${STAGING_DIR}"
  if [[ ! -x "${STAGING_DIR}/opt/osquery/bin/osqueryd" ]]; then
    echo "osquery tarball did not contain opt/osquery/bin/osqueryd." >&2
    exit 1
  fi

  mkdir -p "${OSQUERY_PREFIX}"
  cp -a "${STAGING_DIR}/opt/osquery/." "${OSQUERY_PREFIX}/"
  # The tarball stores files under the build account; osquery refuses to run unless the
  # binary and its parent directories are owned by root (safePermissions check).
  chown -R 0:0 "${OSQUERY_PREFIX}"
  ln -sf "${OSQUERY_PREFIX}/bin/osqueryd" /usr/bin/osqueryd
  ln -sf "${OSQUERY_PREFIX}/bin/osqueryd" /usr/bin/osqueryi
  ln -sf "${OSQUERY_PREFIX}/bin/osqueryctl" /usr/bin/osqueryctl
  mkdir -p /var/osquery /var/log/osquery
}

write_checkpost_config() {
  mkdir -p /etc/osquery
  printf '%s' "${ENROLL_SECRET}" > "${SECRET_PATH}"
  chmod 600 "${SECRET_PATH}"

  cat > "${FLAGS_PATH}" <<EOF
--host_identifier=uuid
--enroll_secret_path=${SECRET_PATH}
--tls_hostname=${TLS_HOSTNAME}
--enroll_tls_endpoint=/api/v1/osquery/enroll
--config_plugin=tls
--config_tls_endpoint=/api/v1/osquery/config
--logger_plugin=tls
--logger_tls_endpoint=/api/v1/osquery/logger
--distributed_plugin=tls
--distributed_tls_read_endpoint=/api/v1/osquery/distributed/read
--distributed_tls_write_endpoint=/api/v1/osquery/distributed/write
--logger_tls_period=10
--distributed_interval=10
--disable_distributed=false
--config_refresh=60
EOF
}

write_systemd_unit() {
  mkdir -p "$(dirname "${SERVICE_PATH}")"
  cat > "${SERVICE_PATH}" <<EOF
[Unit]
Description=osquery daemon
After=network.target

[Service]
TimeoutStartSec=0
ExecStart=${OSQUERY_PREFIX}/bin/osqueryd --flagfile=${FLAGS_PATH}
Restart=on-failure
KillMode=control-group
KillSignal=SIGTERM
TimeoutStopSec=15
CPUQuota=20%

[Install]
WantedBy=multi-user.target
EOF
}

restart_osquery() {
  if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload
    systemctl enable --now osqueryd
  else
    echo "systemd not detected; osquery is installed and configured."
    echo "Start it with: ${OSQUERY_PREFIX}/bin/osqueryd --flagfile=${FLAGS_PATH}"
  fi
}

require_root
install_osquery_if_missing
write_checkpost_config
write_systemd_unit
restart_osquery

echo "osquery configured for Checkpost."
echo "Verify with: sudo systemctl status osqueryd --no-pager"
