<h2>{{.Title}} — {{.Kind}}</h2>
<p>Severity: {{.Severity}}</p>
<table cellpadding="6" cellspacing="0" style="border-collapse:collapse;border:1px solid #ddd">
  <thead>
    <tr style="background:#f5f5f5">
      <th align="left" style="border:1px solid #ddd">Host</th>
      <th align="left" style="border:1px solid #ddd">Summary</th>
      <th align="left" style="border:1px solid #ddd">Resolution</th>
    </tr>
  </thead>
  <tbody>
  {{- range .Items}}
    <tr>
      <td style="border:1px solid #ddd">{{.Host}}</td>
      <td style="border:1px solid #ddd">{{.Summary}}</td>
      <td style="border:1px solid #ddd">{{if .Resolution}}{{.Resolution}}{{else}}—{{end}}</td>
    </tr>
  {{- end}}
  </tbody>
</table>
